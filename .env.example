# ═══════════════════════════════════════════════════════════════
# 동네비서 환경변수 템플릿
# 복사: cp .env.example .env  →  실제 값으로 채워 넣으세요
# 절대 .env 파일을 Git에 커밋하지 마세요 (.gitignore에 포함됨)
#
# [영역 구분]
#   TANTAN_*   → 탄탄제작소 인프라 설정 (운영팀 관리)
#   DNBSIR_*   → 동네비서 앱 설정 (개발팀 관리)
#   레거시 키명  → 기존 코드 호환 (점진적 마이그레이션 중)
# ═══════════════════════════════════════════════════════════════


# ───────────────────────────────────────────
# [탄탄제작소] 인프라 영역 (TANTAN_ prefix)
# ───────────────────────────────────────────

# 데이터베이스 (PostgreSQL — 한국 서버)
TANTAN_DATABASE_URL=postgresql://dnbsir:password@localhost:5432/dnbsir
TANTAN_DB_HOST=localhost
TANTAN_DB_PORT=5432
TANTAN_DB_NAME=dnbsir
TANTAN_DB_USER=dnbsir
TANTAN_DB_PASSWORD=your_db_password_here

# 서버 설정
TANTAN_SERVER_REGION=kr-central1
TANTAN_PORT=8080

# 미디어 워커 연동
TANTAN_UPLOAD_SECRET=your_shared_secret_here
TANTAN_GPU_API_URL=http://tantanfab.com/api/gpu
TANTAN_REDIS_URL=redis://localhost:6379/0

# GCP (탄탄제작소 클라우드 계정)
TANTAN_GCP_PROJECT_ID=your_gcp_project_id
TANTAN_GCP_REGION=asia-northeast3


# ───────────────────────────────────────────
# [동네비서] 앱 영역 (레거시 키명 — 호환)
# ───────────────────────────────────────────

# AI / LLM
GOOGLE_API_KEY=your_gemini_api_key_here

# SMS (Solapi)
SOLAPI_API_KEY=your_solapi_api_key
SOLAPI_API_SECRET=your_solapi_api_secret
SOLAPI_SENDER=01012345678

# 결제 (Toss Payments)
TOSS_CLIENT_KEY=test_ck_your_toss_client_key
TOSS_SECRET_KEY=test_sk_your_toss_secret_key

# Webhook 보안
WEBHOOK_SECRET_TOKEN=your_webhook_secret_token

# 앱 설정
APP_BASE_URL=https://dongnebiseo.com
API_URL=https://api.dnbsir.com
