# AI_Store 환경변수 설정
# 사용법: 이 파일을 .env 로 복사 후 실제 값 입력
#   copy .env.example .env

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [1] Gemini API — LLM 대본 생성 (NotebookLM 그라운딩)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 발급: https://aistudio.google.com/apikey (무료)
# 비용: 영상 1개 대본 생성 ≈ $0.000015 (사실상 무료)
# 무료 한도: 분당 15회, 일 1500회
GEMINI_API_KEY=AIza여기에_Gemini_API_키_입력

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [2] Google Cloud TTS — 뉴스앵커 톤 나레이션
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 발급: https://console.cloud.google.com
#   → API 및 서비스 → 사용자 인증 정보 → API 키 만들기
#   → Text-to-Speech API 활성화 필수
# 비용: Neural2 월 100만 자 무료 (영상 1개 ≈ 200자 → 5000개/월 무료)
GOOGLE_CLOUD_TTS_KEY=AIza여기에_Cloud_TTS_API_키_입력

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [3] OpenAI API — 폴백용 (선택)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GEMINI_API_KEY 또는 GOOGLE_CLOUD_TTS_KEY가 없을 때 자동 폴백
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-여기에_OpenAI_API_키_입력

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [4] Celery / Redis (내부 큐)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
