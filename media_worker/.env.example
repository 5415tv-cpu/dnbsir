# ─────────────────────────────────────────────────────────────
# media_worker 환경변수 템플릿
# 복사: cp .env.example .env  →  값을 채워 넣으세요
# ─────────────────────────────────────────────────────────────

# Redis 브로커 (탄탄제작소 인프라)
MEDIA_WORKER_REDIS_URL=redis://localhost:6379/1

# ComfyUI 연결 (로컬 GPU 서버)
MEDIA_WORKER_COMFYUI_HOST=localhost
MEDIA_WORKER_COMFYUI_PORT=8188

# Vultr GPU 서버 연동 (탄탄제작소 클라우드)
MEDIA_WORKER_TANTAN_GPU_API_URL=http://tantanfab.com/api/gpu
MEDIA_WORKER_TANTAN_API_KEY=your_tantan_api_key_here

# 동네비서 업로드 토큰 시크릿 (서비스 경계 인증)
MEDIA_WORKER_DNBSIR_UPLOAD_SECRET=your_shared_secret_here
MEDIA_WORKER_DNBSIR_API_BASE=https://api.dnbsir.com

# 출력 디렉토리
MEDIA_WORKER_OUTPUT_DIR=/app/media_output
